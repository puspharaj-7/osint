# =============================================
# OSINT Platform — API Keys Configuration
# Copy this file to .env and fill in your keys
# =============================================

# --- HaveIBeenPwned (Breach Checks) ---
# Free tier available. Get key at: https://haveibeenpwned.com/API/Key
VITE_HIBP_API_KEY=

# --- WhoisXML API (WHOIS / DNS History) ---
# Free tier: 500 req/month. https://whois.whoisxmlapi.com/
VITE_WHOISXML_API_KEY=

# --- IPinfo.io (IP Geolocation + ASN) ---
# Free tier: 50k req/month. https://ipinfo.io/signup
VITE_IPINFO_TOKEN=

# --- VirusTotal (Threat Intelligence) ---
# Free public API. https://www.virustotal.com/gui/join-us
VITE_VIRUSTOTAL_API_KEY=

# --- OpenCorporates (Company Registry) ---
# Free tier available. https://opencorporates.com/api_accounts/new
VITE_OPENCORPORATES_API_KEY=

# --- Hunter.io (Email Intelligence) ---
# Free tier: 25 req/month. https://hunter.io/users/sign_up
VITE_HUNTER_API_KEY=

# --- OpenSanctions (Sanctions & PEP Lists) ---
# Free public API (no key required for basic use)
# Premium key for higher limits: https://www.opensanctions.org/api/
VITE_OPENSANCTIONS_API_KEY=

# --- Abstract API (Phone Validation) ---
# Free tier available. https://www.abstractapi.com/
VITE_ABSTRACT_API_KEY=

# =============================================
# IMPORTANT: Never commit .env to source control
# .env is already in .gitignore
# =============================================
